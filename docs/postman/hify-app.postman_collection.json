    },
    {
      "name": "权限矩阵（自包含：需 member 账号 + 填 memberUsername/memberPassword）",
      "item": [
        {
          "name": "P0. admin 建一个测试 app → 存 permAppId",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/app/apps",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "app", "apps" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"权限测试-admin拥有\",\n  \"type\": \"chat\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// 防重名：若上一轮残留同名，先尝试删（忽略失败）。这里简单依赖软删可同名重建，直接建即可。"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.code === 200) { pm.collectionVariables.set('permAppId', j.data.id); pm.test('建成 code=200', () => pm.expect(j.code).to.eql(200)); }",
                  "else { pm.test('已存在(409)也可接受，请先删除残留再重跑', () => pm.expect(j.code).to.eql(10006)); }"
                ]
              }
            }
          ]
        },
        {
          "name": "P1. 登录(member) → 存 memberToken",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/identity/login",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "identity", "login" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{memberUsername}}\",\n  \"password\": \"{{memberPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "pm.test('member 登录成功', () => pm.expect(j.code).to.eql(200));",
                  "pm.collectionVariables.set('memberToken', j.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "P2. member 可见 admin 的 app（全员可见，期望 200）",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{memberToken}}", "type": "string" } ] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/app/apps/{{permAppId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "app", "apps", "{{permAppId}}" ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('全员可见 code=200', () => pm.expect(pm.response.json().code).to.eql(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "P3. member 改他人 app（期望 403/10004）",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{memberToken}}", "type": "string" } ] },
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/app/apps/{{permAppId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "v1", "app", "apps", "{{permAppId}}" ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"member乱改\",\n  \"modelId\": null,\n  \"config\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 403', () => pm.response.to.have.status(403));",
                  "pm.test('业务码 10004', () => pm.expect(pm.response.json().code).to.eql(10004));"
