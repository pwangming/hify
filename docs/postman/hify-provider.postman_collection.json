            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "provider",
            "providers",
            "{{providerId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"通义千问-生产(改名)\",\n  \"protocol\": \"openai\",\n  \"baseUrl\": \"https://dashscope.aliyuncs.com/compatible-mode/v1\",\n  \"apiKey\": \"\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('code=200', () => pm.expect(json.code).to.eql(200));",
              "pm.test('名称已更新', () => pm.expect(json.data.name).to.eql('通义千问-生产(改名)'));",
              "pm.test('apiKey 留空 → tail 不变(abcd)', () => pm.expect(json.data.apiKeyTail).to.eql('abcd'));"
            ]
          }
        }
      ]
    },
