# 敏感配置（deploy/.env.example 入库，真实 .env 不入库）
.env
*.env.local

# Java / Maven（server/）
target/
build/
*.class
*.jar
!.mvn/wrapper/maven-wrapper.jar

# Node / Vite（web/）
node_modules/
dist/
*.local

# IDE
.idea/
.vscode/
*.iml

# 系统与日志
.DS_Store
logs/
*.log

# 本地运行态（start.sh/stop.sh 的 PID 文件与日志）
.run/

# 本地 compose 覆盖：docker compose 自动加载，提交会静默改变生产隔离行为，禁止入库
docker-compose.override.yml
