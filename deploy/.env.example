# Hify 环境变量样例。复制为 deploy/.env 并按需修改；真实 .env 不入库（见 .gitignore）。
# 当前阶段只用到数据库相关项；模型 API Key、JWT 主密钥等后续接入时再补。

# --- PostgreSQL（docker-compose 与应用共用）---
POSTGRES_DB=hify
POSTGRES_USER=hify
POSTGRES_PASSWORD=hify

# --- 应用连接数据库（不配则用 application.yml 里的本地默认值）---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hify
# SPRING_DATASOURCE_USERNAME=hify
# SPRING_DATASOURCE_PASSWORD=hify

# --- JWT 认证（生产务必改成随机长串，至少 32 字节）---
# 生成示例：openssl rand -base64 48
HIFY_JWT_SECRET=dev-only-hify-jwt-secret-please-override-in-env-0123456789
# HIFY_JWT_EXPIRE_MINUTES=1440
